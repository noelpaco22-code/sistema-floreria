<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0">
    <title>Elite Admin | Florería Margarita</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/panel_admin.css">
    <style>
        /* Estilos críticos e hidratación visual */
        :root {
            --primary-gold: #d4af37;
            --dark-bg: #1a1a1a;
            --border: #333;
            --danger: #ff4d4d;
        }

        .text-danger-bold { color: var(--danger) !important; font-weight: bold; }
        .img-preview { width: 50px; height: 50px; object-fit: cover; border-radius: 8px; border: 1px solid var(--border); }
        .gold-text { color: var(--primary-gold); }
        
        .btn-edit { background: #3498db; color: white; border: none; padding: 8px; border-radius: 5px; cursor: pointer; transition: 0.2s; margin-right: 5px; }
        .btn-edit:hover { background: #2980b9; transform: scale(1.05); }

        tr { transition: all 0.3s ease; }
        .search-bar input:focus { outline: none; border-color: var(--primary-gold) !important; box-shadow: 0 0 8px rgba(212, 175, 55, 0.2); }

        .btn-huella {
            background: #111;
            color: var(--primary-gold);
            border: 1px solid var(--primary-gold);
            padding: 12px;
            border-radius: 8px;
            width: calc(100% - 40px);
            margin: 10px 20px;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            transition: 0.3s;
            font-family: 'Poppins', sans-serif;
            font-weight: 600;
        }
        .btn-huella:hover { background: var(--primary-gold); color: black; }

        #toast-container { position: fixed; top: 20px; right: 20px; z-index: 9999; }
        .toast { background: #333; color: white; padding: 12px 20px; border-radius: 8px; margin-bottom: 10px; border-left: 4px solid var(--primary-gold); display: flex; align-items: center; gap: 10px; animation: slideIn 0.3s ease; }
        @keyframes slideIn { from { transform: translateX(100%); } to { transform: translateX(0); } }
.estado-select {
    background: #1a1a1a;
    color: white;
    border: 1px solid var(--primary-gold);
    border-radius: 4px;
    padding: 5px;
    cursor: pointer;
    font-family: 'Poppins', sans-serif;
}
.estado-select option[value="pendiente"] { color: #3498db; }
.estado-select option[value="proceso"] { color: #f1c40f; }
.estado-select option[value="completado"] { color: #2ecc71; }
@keyframes pulso {
    0% { opacity: 1; }
    50% { opacity: 0.5; }
    100% { opacity: 1; }
}
    </style>
</head>
<body>

    <div class="mobile-header">
        <h2>SYSTEM MARGARITA</h2>
    </div>

    <div id="toast-container"></div>

    <aside class="sidebar">
        <h2 class="sidebar-brand">SYSTEM MARGARITA</h2>
        
    <nav class="nav-menu">
    <ul>
        <li class="nav-item">
            <a href="#" class="nav-link active" onclick="cambiarVista('dashboard', this)">
                <i class="fas fa-th-large"></i> <span>Dashboard</span>
            </a>
        </li>

        <li class="nav-item">
            <a href="#" class="nav-link" onclick="cambiarVista('pedidos', this)">
                <i class="fas fa-shopping-cart"></i> <span>Pedidos</span>
            </a>
        </li>

        <li class="nav-item">
            <a href="#" class="nav-link" onclick="cambiarVista('usuarios', this)">
                <i class="fas fa-users"></i> <span>Usuarios</span>
            </a>
        </li>
    </ul>
</nav>

        <button class="btn-huella" onclick="registrarHuella()">
            <i class="fas fa-fingerprint"></i> <span>Vincular Huella</span>
        </button>

        <a href="/logout" class="logout">
            <i class="fas fa-sign-out-alt"></i> <span>Cerrar Sesión</span>
        </a>
    </aside>
<main class="main">

    <div id="section-dashboard">
        
        <div class="stats-grid">
            <div class="stat-card">
                <h3>Ventas Totales</h3>
                <div class="value"><%= pedidos.reduce((acc, p) => acc + (parseFloat(p.total) || 0), 0).toLocaleString() %> Bs</div>
            </div>
            <div class="stat-card">
                <h3>Productos</h3>
                <div class="value" id="prod-count"><%= productos.length %></div>
            </div>
            <div class="stat-card">
                <h3>Stock Valorizado</h3>
                <div class="value"><%= productos.reduce((acc, p) => acc + (Number(p.precio || 0) * Number(p.stock || 0)), 0).toLocaleString() %> Bs</div>
            </div>
            <div class="stat-card">
                <h3>Categorías</h3>
                <div class="value" id="cat-count"><%= categorias.length %></div>
            </div>
        </div>

        <div class="grid-sections">
            <section class="content-box inventory-section">
                <div class="box-header" style="display: flex; align-items: center; gap: 15px;">
                    <h2>Inventario</h2>
                    <div class="search-bar" style="flex: 1; position: relative;">
