                    <label>Imagen</label>
                    <input type="file" name="imagen" id="inputImagen" class="form-control" accept="image/*">
                    <img id="preview-img" alt="Vista previa" style="width:100px; height:100px; object-fit:cover; margin-top:10px; border-radius:8px; display:none; border: 1px solid var(--primary-gold)">
                </div>
                <button type="submit" class="btn-primary" style="width:100%; padding: 14px;">Publicar</button>
            </form>
        </div>
