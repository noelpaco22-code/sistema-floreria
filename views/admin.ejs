            <button type="button" class="close-btn" onclick="closeModal('modalCat')">&times;</button>
            <h2 style="margin-bottom:20px">Nueva Categoría</h2>
            <form action="/admin/agregar-categoria" method="POST" onsubmit="return handleFormSubmit(event, this, 'Categoría creada')">
