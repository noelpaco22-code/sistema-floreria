                        <input type="text" id="search-input" placeholder="Buscar producto..." style="width: 100%; padding: 10px 10px 10px 35px; border-radius: 8px; border: 1px solid #333; background: #1a1a1a; color: white; font-size: 16px;">
                    </div>
                    <button class="btn-primary" onclick="openModal('modalProd')">+ Nuevo</button>
                </div>
                
               <div class="table-wrapper">
    <table>
        <thead>
            <tr><th>Imagen</th><th>Nombre</th><th>Stock</th><th>Precio</th><th>Acciones</th></tr>
        </thead>
        <tbody id="product-table-body">
            <% productos.forEach(p => { %>
            <tr id="row-prod-<%= p.id %>">
                <td>
                    <img src="<%= p.imagen_url %>" 
                         class="img-preview" 
                         loading="lazy"
                         onclick="abrirImagen('<%= p.imagen_url %>')"
                         style="cursor: pointer;">
                </td>
                <td><strong><%= p.nombre %></strong><br><small class="gold-text"><%= p.categoria %></small></td>
                <td class="stock-cell <%= p.stock <= 5 ? 'text-danger-bold' : '' %>">
                    <span class="stock-val"><%= p.stock %></span>
                    <% if(p.stock <= 5) { %> <i class="fas fa-exclamation-triangle"></i> <% } %>
                </td>
                <td><%= p.precio %> Bs</td>
                <td>
                    <button class="btn-edit" onclick="prepararEdicion('<%= p.id %>', '<%= p.nombre %>', '<%= p.precio %>', '<%= p.stock %>', '<%= p.categoria_id %>')"><i class="fas fa-edit"></i></button>
                    <button class="btn-del" onclick="abrirConfirmar('/admin/eliminar/<%= p.id %>', 'Producto eliminado', 'row-prod-<%= p.id %>', 'prod-count')"><i class="fas fa-trash"></i></button>
                </td>
            </tr>
            <% }) %>
        </tbody>
    </table>
</div>
            </section>

            <section class="content-box cat-section">
                <div class="box-header">
                    <h2>Categorías</h2>
                    <button class="btn-primary" onclick="openModal('modalCat')">+</button>
                </div>
                <div class="table-wrapper">
                    <table>
                        <thead>
                            <tr><th>Nombre</th><th style="text-align: right;">Acción</th></tr>
                        </thead>
                        <tbody id="category-table-body">
                            <% categorias.forEach(c => { %>
                            <tr id="row-cat-<%= c.id %>">
                                <td><%= c.nombre %></td>
                                <td style="text-align: right;">
                                    <button class="btn-del" onclick="abrirConfirmar('/admin/eliminar-categoria/<%= c.id %>', 'Categoría eliminada', 'row-cat-<%= c.id %>', 'cat-count')"><i class="fas fa-times"></i></button>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </section>
        </div>
    </div>
<section id="section-pedidos" class="content-box" style="display: none;">
    <div class="box-header">
        <h2>Gestión de Pedidos</h2>
    </div>
    <div class="table-wrapper">
        <table>
            <thead>
                <tr>
                    <th>Cliente</th>
                    <th>Total</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody id="pedidos-table-body">
                <% pedidos.forEach(p => { %>
                    <tr>
                        <td><%= p.cliente_nombre %></td>
                        <td><%= p.total %> Bs</td>
                       <td>
    <select class="estado-select" data-pedido-id="<%= p.id %>" onchange="cambiarEstadoPedido(this)">
        <option value="pendiente" <%= p.estado === 'pendiente' ? 'selected' : '' %>>🔵 Pendiente</option>
        <option value="proceso" <%= p.estado === 'proceso' ? 'selected' : '' %>>🟡 En Proceso</option>
        <option value="completado" <%= p.estado === 'completado' ? 'selected' : '' %>>🟢 Completado</option>
    </select>
</td>
                       <td>
                        <button class="btn-edit" onclick="verDetallePedido('<%= p.id %>')"><i class="fas fa-eye"></i>
                       </button>
                        <button class="btn-del" onclick="abrirConfirmarPedido('<%= p.id %>')" title="Eliminar pedido">
        <i class="fas fa-trash"></i>
    </button>
                      </td>
                    </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</section>
<section id="section-usuarios" class="content-box" style="display: none;">
    <div class="box-header">
        <h2>Gestión de Usuarios</h2>
        <button class="btn-primary" onclick="abrirModalAgregarUsuario()">+ Nuevo Usuario</button>
    </div>
    <div class="table-wrapper">
        <table id="user-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Nombre</th>
                    <th>Email</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody id="user-table-body">
                <!-- Los usuarios se cargarán aquí -->
            </tbody>
        </table>
    </div>
</section>

</main>

    <div class="modal-overlay" id="modalEditar">
        <div class="modal-card">
            <button type="button" class="close-btn" onclick="closeModal('modalEditar')">&times;</button>
            <h2 style="margin-bottom:20px">Editar Producto</h2>
            <form id="formEditarFlor" action="/admin/editar-flor" method="POST" enctype="multipart/form-data" onsubmit="return handleFormSubmit(event, this, 'Producto actualizado')">
                <input type="hidden" name="id" id="edit-id">
                <div class="form-group">
                    <label>Nombre</label>
                    <input type="text" name="nombre" id="edit-nombre" class="form-control" required>
                </div>
                <div style="display:flex; gap:10px">
                    <div class="form-group" style="flex:1">
                        <label>Precio (Bs)</label>
                        <input type="number" name="precio" id="edit-precio" step="0.01" class="form-control" required>
                    </div>
                    <div class="form-group" style="flex:1">
                        <label>Stock</label>
                        <input type="number" name="stock" id="edit-stock" class="form-control" required>
