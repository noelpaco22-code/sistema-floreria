<div id="modalImagenGrande" style="display:none; position:fixed; z-index:1000; left:0; top:0; width:100%; height:100%; background-color: rgba(0,0,0,0.8); justify-content:center; align-items:center;">
    <span onclick="document.getElementById('modalImagenGrande').style.display='none'" style="position:absolute; top:20px; right:30px; color:white; font-size:40px; cursor:pointer;">&times;</span>
    <img id="imagenAmpliada" src="" style="max-width:80%; max-height:80%; border: 3px solid white;">
</div>
<script>
    /* --- UTILIDADES WEBAUTHN --- */
    function bufferDecode(value) {
        return Uint8Array.from(atob(value.replace(/-/g, '+').replace(/_/g, '/')), c => c.charCodeAt(0));
    }

    function bufferEncode(value) {
        return btoa(String.fromCharCode.apply(null, new Uint8Array(value)))
            .replace(/\+/g, "-").replace(/\//g, "_").replace(/=/g, "");
    }

    async function registrarHuella() {
        try {
            showToast("Iniciando sensor...");
            const resp = await fetch('/admin/webauthn-register-options');
            if (!resp.ok) throw new Error("Error de servidor");
            
            const options = await resp.json();
            options.challenge = bufferDecode(options.challenge);
            options.user.id = bufferDecode(options.user.id);
            if (options.excludeCredentials) {
                options.excludeCredentials.forEach(c => c.id = bufferDecode(c.id));
            }

            const credential = await navigator.credentials.create({ publicKey: options });

            const credentialForServer = {
                id: credential.id,
                rawId: bufferEncode(credential.rawId),
                type: credential.type,
                response: {
                    attestationObject: bufferEncode(credential.response.attestationObject),
                    clientDataJSON: bufferEncode(credential.response.clientDataJSON),
                }
            };

            const verifResp = await fetch('/admin/webauthn-verify-register', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(credentialForServer)
            });

            const result = await verifResp.json();
            if (result.success) showToast("✅ Huella vinculada");
            else showToast("❌ Error: " + result.error);

        } catch (err) {
            console.error(err);
            showToast("❌ No se pudo completar el registro");
        }
    }

    /* --- GESTIÓN DE MODALES --- */
    function openModal(id) { 
        document.getElementById(id).style.display = 'flex';
        document.body.style.overflow = 'hidden';
    }
    
    function closeModal(id) { 
        const m = document.getElementById(id);
        if(m) m.style.display = 'none'; 
        document.body.style.overflow = 'auto';
        if(id === 'modalProd') {
            document.getElementById('preview-img').style.display = 'none';
            document.getElementById('formNuevaFlor').reset();
        }
    }

    function prepararEdicion(id, nombre, precio, stock, categoriaId) {
        document.getElementById('edit-id').value = id;
        document.getElementById('edit-nombre').value = nombre;
        document.getElementById('edit-precio').value = precio;
        document.getElementById('edit-stock').value = stock;
        document.getElementById('edit-categoria').value = categoriaId;
        openModal('modalEditar');
    }

    /* --- BUSCADOR Y PREVIEW --- */
    document.getElementById('inputImagen')?.addEventListener('change', function(e) {
        if(this.files && this.files[0]) {
            const reader = new FileReader();
            reader.onload = (e) => {
                const img = document.getElementById('preview-img');
                img.src = e.target.result;
                img.style.display = 'block';
            }
            reader.readAsDataURL(this.files[0]);
        }
    });

    let searchTimeout;
    document.getElementById('search-input')?.addEventListener('input', function() {
        clearTimeout(searchTimeout);
        searchTimeout = setTimeout(() => {
            const valor = this.value.toLowerCase();
            document.querySelectorAll('#product-table-body tr').forEach(fila => {
                const nombre = fila.querySelector('td:nth-child(2)').textContent.toLowerCase();
                fila.style.display = nombre.includes(valor) ? '' : 'none';
            });
        }, 250);
    });

    // Busca esta función en tu <script> y modifícala así:
function abrirConfirmar(url, mensaje, rowId, countId) {
    const form = document.getElementById('formConfirmarBorrado');
    form.action = url;
    
    form.onsubmit = async (e) => {
        e.preventDefault();
        try {
            const res = await fetch(url, { method: 'POST' });
            
            if (res.ok) {
                showToast(mensaje);
                const row = document.getElementById(rowId);
                if(row) {
                    row.style.opacity = '0';
                    setTimeout(() => row.remove(), 300);
                }
                const badge = document.getElementById(countId);
                if(badge) badge.innerText = Math.max(0, parseInt(badge.innerText) - 1);
                closeModal('modalConfirmar');
            } else {
                // AQUÍ ESTÁ LA MAGIA: Capturamos el error real
                const errorData = await res.json();
                showToast("❌ " + (errorData.error || "No se pudo eliminar"));
                closeModal('modalConfirmar');
            }
        } catch (err) { 
            showToast("❌ Error de red, verifica tu conexión"); 
        }
    };
    openModal('modalConfirmar');
}

    async function handleFormSubmit(event, form, successMsg) {
        event.preventDefault();
        const btn = form.querySelector('button[type="submit"]');
        const originalText = btn.innerText;
        btn.innerText = "Procesando...";
        btn.disabled = true;

        try {
            const formData = new FormData(form);
            const response = await fetch(form.action, {
                method: 'POST',
                body: form.enctype === "multipart/form-data" ? formData : new URLSearchParams(formData)
            });

            if (response.ok) {
                showToast(successMsg);
                setTimeout(() => location.reload(), 800);
            } else {
                showToast("Error en el servidor");
            }
        } catch (error) {
            showToast("Error de conexión");
        } finally {
            btn.innerText = originalText;
            btn.disabled = false;
        }
        return false;
    }

    function showToast(message) {
        const container = document.getElementById('toast-container');
        const toast = document.createElement('div');
        toast.className = 'toast';
        toast.innerHTML = `<i class="fas fa-info-circle"></i> <span>${message}</span>`;
        container.appendChild(toast);
        setTimeout(() => {
            toast.style.opacity = '0';
            setTimeout(() => toast.remove(), 500);
        }, 3000);
    }

    window.onclick = (e) => { 
        if(e.target.classList.contains('modal-overlay')) closeModal(e.target.id);
    }
    
async function cargarUsuarios() {
    const tbody = document.getElementById('user-table-body');
    tbody.innerHTML = '<tr><td colspan="4" style="text-align: center;">Cargando usuarios...</td></tr>';
    
    try {
        const res = await fetch('/admin/api/usuarios-con-estado', {
            credentials: 'include',
            headers: {
                'Accept': 'application/json'
            }
        });
        const usuarios = await res.json();
        
        if (usuarios.length === 0) {
            tbody.innerHTML = '<tr><td colspan="4" style="text-align: center;">No hay usuarios registrados</td></tr>';
            return;
        }
        
        tbody.innerHTML = usuarios.map(u => `
            <tr id="row-user-${u.id}">
                <td>${u.id}</td>
                <td>
                    ${u.nombre}
                    <span style="
                        display: inline-block;
                        width: 10px;
                        height: 10px;
                        border-radius: 50%;
                        background-color: ${u.estado === 'online' ? '#2ecc71' : '#95a5a6'};
                        margin-left: 8px;
                        box-shadow: 0 0 5px ${u.estado === 'online' ? '#2ecc71' : '#95a5a6'};
                        animation: ${u.estado === 'online' ? 'pulso 2s infinite' : 'none'};
                    " title="${u.estado === 'online' ? 'En línea ahora' : 'Desconectado'}"></span>
                </td>
                <td>${u.email}</td>
                <td>
                    <button class="btn-del" onclick="confirmarEliminarUsuario(${u.id}, '${u.nombre}')" title="Eliminar usuario">
                        <i class="fas fa-trash"></i>
                    </button>
                </td>
            </tr>
        `).join('');
    } catch (e) {
        console.error("Error al cargar usuarios:", e);
        tbody.innerHTML = '<tr><td colspan="4" style="text-align: center; color: #ff4d4d;">Error al cargar usuarios</td></tr>';
    }
}

// ===== NUEVA FUNCIÓN PARA ACTUALIZACIÓN AUTOMÁTICA =====
let intervaloUsuarios = null;

function iniciarActualizacionAutomatica() {
    // Limpiar intervalo anterior si existe
    if (intervaloUsuarios) {
        clearInterval(intervaloUsuarios);
    }
    
    // Actualizar cada 10 segundos
    intervaloUsuarios = setInterval(() => {
        const seccionUsuarios = document.getElementById('section-usuarios');
        if (seccionUsuarios && seccionUsuarios.style.display === 'block') {
            cargarUsuarios();
        }
    }, 10000); // 10000ms = 10 segundos
}

// ===== FUNCIÓN MODIFICADA cambiarVista =====
async function cambiarVista(vista, elemento) {
    // 1. Manejo de clases activas
    document.querySelectorAll('.nav-link').forEach(link => link.classList.remove('active'));
    elemento.classList.add('active');

    // 2. Ocultar todas las secciones
    document.getElementById('section-dashboard').style.display = 'none';
    document.getElementById('section-usuarios').style.display = 'none';
    document.getElementById('section-pedidos').style.display = 'none';

    // 3. Mostrar solo la que corresponde
    switch(vista) {
        case 'dashboard':
            document.getElementById('section-dashboard').style.display = 'block';
            break;
        case 'usuarios':
            document.getElementById('section-usuarios').style.display = 'block';
            cargarUsuarios(); // Carga inicial
            iniciarActualizacionAutomatica(); // Iniciar actualización cada 3 segundos
            break;
        case 'pedidos':
            document.getElementById('section-pedidos').style.display = 'block';
            console.log("Cargando sección de pedidos...");
            break;
        default:
            document.getElementById('section-dashboard').style.display = 'block';
    }
}
/* --- FUNCIÓN PARA VER DETALLE DE PEDIDOS --- */
async function verDetallePedido(id) {
    const modal = document.getElementById('modalDetalle');
    const contenido = document.getElementById('detalle-contenido');
    openModal('modalDetalle');
    contenido.innerHTML = "Cargando detalles...";

    try {
        const res = await fetch(`/admin/api/pedido/${id}`, {
    credentials: 'include'
});
const data = await res.json();  // ✅ AHORA SÍ, FETCH CERRADO
        
        
        let html = `
            <table style="width:100%; border-collapse: collapse; margin-top: 10px;">
                <thead>
                    <tr style="border-bottom: 1px solid #333;">
                        <th style="text-align: left; padding: 8px;">Imagen</th>
                        <th style="text-align: left; padding: 8px;">Producto</th>
                        <th style="text-align: center; padding: 8px;">Cant.</th>
                        <th style="text-align: right; padding: 8px;">Precio</th>
                    </tr>
                </thead>
                <tbody>`;

        data.forEach(item => {
            html += `
                <tr style="border-bottom: 1px solid #222;">
                    <td style="padding: 8px;">
                        <img src="${item.imagen_url}" 
                             style="width: 50px; height: 50px; object-fit: cover; border-radius: 5px; cursor: pointer;"
                             onclick="abrirImagen('${item.imagen_url}')">
                    </td>
                    <td style="padding: 8px;">${item.producto_nombre}</td>
                    <td style="text-align: center; padding: 8px;">${item.cantidad}</td>
                    <td style="text-align: right; padding: 8px;">${item.precio_unitario} Bs</td>
                </tr>`;
        });

        html += `</tbody></table>`;
        contenido.innerHTML = html;
        
    } catch (e) {
        console.error(e);
        contenido.innerHTML = "No se pudieron cargar los detalles.";
    }
}

/* --- FUNCIÓN PARA ELIMINAR PEDIDOS --- */
function abrirConfirmarPedido(id) {
    const form = document.getElementById('formConfirmarBorrado');
    form.action = '/admin/eliminar-pedido/' + id;
    form.onsubmit = async (e) => {
        e.preventDefault();
        try {
            const res = await fetch('/admin/eliminar-pedido/' + id, { method: 'POST', credentials: 'include' });
            
            if (res.ok) {
                showToast("✅ Pedido eliminado");
                const row = document.querySelector(`button[onclick="abrirConfirmarPedido('${id}')"]`).closest('tr');
                if(row) {
                    row.style.opacity = '0';
                    setTimeout(() => row.remove(), 300);
                }
                closeModal('modalConfirmar');
            } else {
                const errorData = await res.json();
                showToast("❌ " + (errorData.error || "No se pudo eliminar"));
                closeModal('modalConfirmar');
            }
        } catch (err) { 
            showToast("❌ Error de red"); 
        }
    };
    openModal('modalConfirmar');
}

/* --- FUNCIÓN PARA ELIMINAR USUARIOS --- */
function confirmarEliminarUsuario(id, nombre) {
    const form = document.getElementById('formConfirmarBorrado');
    form.action = '/admin/eliminar-usuario/' + id;
    
    form.onsubmit = async (e) => {
        e.preventDefault();
        try {
            const res = await fetch('/admin/eliminar-usuario/' + id, { 
                method: 'POST',
                credentials: 'include' 
            });
            const data = await res.json();
            
            if (data.success) {
                showToast(`✅ Usuario "${nombre}" eliminado`);
                const row = document.getElementById(`row-user-${id}`);
                if(row) {
                    row.style.opacity = '0';
                    setTimeout(() => {
                        row.remove();
                        if (document.querySelectorAll('#user-table-body tr').length === 0) {
                            document.getElementById('user-table-body').innerHTML = '<tr><td colspan="4" style="text-align: center;">No hay usuarios registrados</td></tr>';
                        }
                    }, 300);
                }
                closeModal('modalConfirmar');
            } else {
                showToast("❌ " + (data.error || "No se pudo eliminar"));
                closeModal('modalConfirmar');
            }
        } catch (err) { 
            showToast("❌ Error de red"); 
            closeModal('modalConfirmar');
        }
    };
    openModal('modalConfirmar');
}

function abrirModalAgregarUsuario() {
    showToast("Los usuarios se registran desde la tienda");
}
function abrirImagen(url) {
    const modal = document.getElementById('modalImagenGrande');
    const imgAmpliada = document.getElementById('imagenAmpliada');
    if (modal && imgAmpliada) {
        imgAmpliada.src = url;
        modal.style.display = 'flex';
    }
}
/* --- FUNCIÓN PARA CAMBIAR ESTADO DE PEDIDO --- */
async function cambiarEstadoPedido(selectElement) {
    const pedidoId = selectElement.getAttribute('data-pedido-id');
    const nuevoEstado = selectElement.value;
    
    try {
        const response = await fetch('/admin/actualizar-estado-pedido', {
            method: 'POST',credentials: 'include',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id: pedidoId, estado: nuevoEstado })
        });
        
        const data = await response.json();
        
        if (data.success) {
            showToast(`✅ Estado actualizado a ${nuevoEstado}`);
            // Actualizar el total de ventas en el dashboard
            actualizarVentasTotales();
        } else {
            showToast("❌ Error al actualizar estado");
        }
    } catch (error) {
        console.error("Error:", error);
        showToast("❌ Error de conexión");
    }
}
/* --- FUNCIÓN PARA ACTUALIZAR VENTAS TOTALES --- */
async function actualizarVentasTotales() {
    try {
        const res = await fetch('/admin/api/ventas-totales', {
            credentials: 'include'});
        const data = await res.json();
        
        const ventasElement = document.querySelector('.stat-card:first-child .value');
        if (ventasElement) {
            ventasElement.textContent = data.total.toLocaleString() + ' Bs';
        }
    } catch (e) {
        console.error("Error al actualizar ventas:", e);
    }
}
