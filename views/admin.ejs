    <div class="modal-overlay" id="modalProd">
        <div class="modal-card">
            <button type="button" class="close-btn" onclick="closeModal('modalProd')">&times;</button>
            <h2 style="margin-bottom:20px">Nueva Flor</h2>
            <form action="/admin/agregar-flor" id="formNuevaFlor" method="POST" enctype="multipart/form-data" onsubmit="return handleFormSubmit(event, this, 'Producto guardado')">
                <div class="form-group">
                    <label>Nombre</label>
                    <input type="text" name="nombre" class="form-control" required>
                </div>
                <div style="display:flex; gap:10px">
                    <div class="form-group" style="flex:1">
                        <label>Precio (Bs)</label>
                        <input type="number" name="precio" step="0.01" class="form-control" placeholder="0.00" required>
                    </div>
                    <div class="form-group" style="flex:1">
                        <label>Stock</label>
                        <input type="number" name="stock" class="form-control" required>
                    </div>
                </div>
                <div class="form-group">
                    <label>Categoría</label>
                    <select name="categoria_id" class="form-control">
